# ============================================================================
#  PBX-NG · .env (NO se versiona — ver .gitignore)
#  Los SECRETOS se dejan VACÍOS a propósito: el instalador (install.sh) los
#  genera por-deployment con openssl. NUNCA pongas contraseñas de ejemplo acá.
#  Para 2 VMs: el 'core' genera edge-join.env con los secretos compartidos y el
#  'edge' los consume — no copies secretos a mano.
# ============================================================================

# ---- Módulos activos (perfiles compose) ----
COMPOSE_PROFILES=core

# ---- App / dominio ----
DOMAIN=
PUBLIC_IP=
TENANT_MODE=single
DEFAULT_COMPANY=Mi Empresa

# ---- Base de datos (DB_PASS lo genera el instalador) ----
DB_HOST=postgres
DB_PORT=5432
DB_NAME=pbxng
DB_USER=pbxng
DB_PASS=

# ---- Hosts de servicios (el instalador los completa según el rol) ----
ASTERISK_HOST=127.0.0.1
REDIS_HOST=127.0.0.1
SBC_HOST=
TURN_HOST=
VOZ_HOST=
MEDIA_HOST=
NPM_HOST=
KAM_HOST=127.0.0.1
KAM_PORT=5060
TRUSTED_NET=

# ---- Secretos (VACÍOS → los genera install.sh; no los pongas a mano) ----
JWT_SECRET=
ARI_USER=pbxng
ARI_PASS=
AMI_USER=pbxng-ami
AMI_PASS=
TURN_USER=pbxng
TURN_PASS=
TURN_CLI_PASS=
# Contraseña inicial del usuario 'admin' (el instalador la genera; se pide
# cambiarla en el primer ingreso). Si queda vacía, app.js usa 'admin' (inseguro).
ADMIN_DEFAULT_PASS=

# ---- Intercom (go2rtc) ----
GO2RTC_MGMT=http://go2rtc:1984

# ---- Release por imagen (deploy por pull/bundle) ----
PBXNG_REGISTRY=pbxng
PBXNG_VERSION=latest
