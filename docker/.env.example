# PBX-NG Docker · copiá a .env y ajustá
DB_NAME=pbxng
DB_USER=pbxng
DB_PASS=cambia_esta_clave
DB_HOST=postgres
JWT_SECRET=cambia_este_secreto_jwt
PUBLIC_IP=
ASTERISK_HOST=asterisk
DOMAIN=pbx.tu-dominio.com

# ----- Topologia de nodos (parametriza las IPs que muestra/usa el dashboard) -----
# Dejalas vacias en single-node (la API deriva defaults sensatos).
#SBC_HOST=            # IP del SBC (Kamailio)
#NPM_HOST=            # IP del proxy inverso (Nginx Proxy Manager)
#TURN_HOST=           # IP del TURN (por defecto = PUBLIC_IP)
#VOZ_HOST=            # IP del servicio de voz (TTS/STT)
#MEDIA_HOST=          # IP para media/externalMedia (por defecto = ASTERISK_HOST)
# Overrides de URL completa de los agentes (opcional; si no, se derivan de los *_HOST):
#AST_AGENT=           # ej http://10.0.0.10:8092
#TURN_AGENT=          # ej http://10.0.0.11:8091
#VM_AGENT=            # ej http://10.0.0.10:8089
