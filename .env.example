# ============================================================
#  PBX-NG · variables de entorno del Control Plane (API)
#  Copiá a .env y completá los valores reales (no se versiona)
# ============================================================
PORT=3000

# PostgreSQL (Asterisk Realtime + CDR + datos de la app)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=pbxng
DB_USER=pbxng
DB_PASS=CHANGE_ME

# Asterisk ARI (control de llamadas)
ARI_URL=http://127.0.0.1:8088
ARI_USER=pbxng
ARI_PASS=CHANGE_ME
ARI_APP=pbxng

# Asterisk AMI (eventos en vivo)
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USER=pbxng-ami
AMI_PASS=CHANGE_ME

# Auth del panel (JWT)
JWT_SECRET=CHANGE_ME

# Web Push (VAPID) - generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC=
VAPID_PRIVATE=CHANGE_ME
VAPID_SUBJECT=mailto:soporte@example.com

# ----- Dashboard (Next.js) -----
# API_URL=http://127.0.0.1:3000

# ----- Topologia de nodos (parametriza IPs que muestra/usa el dashboard via /api/topology) -----
# Dejalas vacias para single-node; la API deriva defaults (asterisk/media -> ASTERISK_HOST, etc).
#DOMAIN=pbx.tu-dominio.com
#PUBLIC_IP=
#SBC_HOST=            # IP del SBC (Kamailio)
#NPM_HOST=            # IP del proxy inverso (NPM)
#TURN_HOST=           # IP del TURN (por defecto = PUBLIC_IP)
#VOZ_HOST=            # IP del servicio de voz (TTS/STT)
#MEDIA_HOST=          # IP de media (por defecto = ASTERISK_HOST)
#AST_AGENT=           # URL completa del agente Asterisk (por defecto http://<ASTERISK_HOST>:8092)
#TURN_AGENT=          # URL completa del agente TURN  (por defecto http://<TURN_HOST>:8091)
#VM_AGENT=            # URL completa del agente de buzon/grabaciones (por defecto http://<ASTERISK_HOST>:8089)

# NOTA: claves de OpenAI (IVR IA), FCM/APNs (push nativo) y SMTP por empresa
# NO van en .env: se cargan cifradas desde el panel (tabla pbxng_settings).
