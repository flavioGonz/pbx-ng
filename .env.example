# ============================================================
#  PBX-NG · variables de entorno del Control Plane (API)
#  Copiá a .env y completá los valores reales (no se versiona)
# ============================================================
PORT=3000

# PostgreSQL (Asterisk Realtime + CDR + datos de la app)
DB_HOST=172.26.20.184
DB_PORT=5432
DB_NAME=pbxng
DB_USER=pbxng
DB_PASS=CHANGE_ME

# Asterisk ARI (control de llamadas)
ARI_URL=http://172.26.20.183:8088
ARI_USER=pbxng
ARI_PASS=CHANGE_ME
ARI_APP=pbxng

# Asterisk AMI (eventos en vivo)
AMI_HOST=172.26.20.183
AMI_PORT=5038
AMI_USER=pbxng-ami
AMI_PASS=CHANGE_ME

# Auth del panel (JWT)
JWT_SECRET=CHANGE_ME

# Web Push (VAPID) - generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC=
VAPID_PRIVATE=CHANGE_ME
VAPID_SUBJECT=mailto:soporte@example.com

# ----- Dashboard (Next.js) -----
# API_URL=http://127.0.0.1:3000

# NOTA: claves de OpenAI (IVR IA), FCM/APNs (push nativo) y SMTP por empresa
# NO van en .env: se cargan cifradas desde el panel (tabla pbxng_settings).
